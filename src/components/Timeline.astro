---
import YearCard from './YearCard.astro';
---

<div class="timeline">
    <div class="timeline-track">
        <YearCard timelineUsage year="2005" title="Milano Foundation" highlight="Established MORADISPLAY in Milano" description="In this year, we initiated our journey with a foundational project in Italy: Established MORADISPLAY in Milano" />
        <YearCard timelineUsage year="2008" title="High-Profile Interiors" highlight="Hyosung, Hyundai, Korean Air, KOSHI KOBAN projects" description="This year marked several high-profile interior design and construction projects: Hyosung Milano, branch interior design and construction; Hyundai Milano, branch interior design and construction; Korean Air Line in Milano, office furniture design and install; KOSHI KOBAN in Milano, branch interior design and construction." />
        <YearCard timelineUsage year="2009" title="International Expansion" highlight="Multiple international exhibition booths" description="We expanded into numerous international exhibitions and booth constructions: MIDO in Milano, SILMO in Paris, LuxePack in Monaco, MadeF in Milano, Salone del Mobile in Milano, Cosmopack.prof. in Bologna, Enersol in Milano, MEDICA in Düsseldorf." />
        <YearCard timelineUsage year="2010" title="Korea Expansion" highlight="Established MORADISPLAY in Korea" description="This year, we expanded our base to Korea: Established MORADISPLAY in Korea" />
        <YearCard timelineUsage year="2011" title="European Projects" highlight="Major European exhibition projects" description="We led several design and booth construction projects across Europe: MIDO in Milano, Cosmopack.prof. in Bologna (KOREAN PAVILION and individual booths), SILMO in Paris, Fotovoltaic in Valencia, HOTEL in Venezia, ICT Roadshow in Milano, Korea preview in Milano, Passion show installation management." />
        <YearCard timelineUsage year="2012" title="Pavilion Success" highlight="Ecofriendly and international pavilions" description="Continued success in pavilion and display booth construction: MIDO in Milano, Cosmopack.prof. in Bologna, CPHI in Spain (Dowachem), OUTDOOR in Friedrichshafen, ESCR in Milano, Korea preview in Milano (Ecofriendly stand), SILMO in Paris, Premiere Vision in Paris." />
        <YearCard timelineUsage year="2013" title="Ecofriendly Emphasis" highlight="Sustainable booth innovations" description="This year we emphasized sustainable and ecofriendly booths: ISPO in Munchen, MIDO in Milano, Cosmopack.prof. in Bologna, Korea preview in Milano, SILMO in Paris, Premiere Vision in Paris, FABRICSTART in Munchen, OUTDOOR in Friedrichshafen." />
        <YearCard timelineUsage year="2014" title="Global Innovation" highlight="Innovative global booth designs" description="We took part in numerous global exhibitions with innovative booth designs: ISPO in Munchen, MIDO in Milano, Cosmopack.prof. in Bologna, Korean Pavilion in Frankfurt and Spain, EMO in Milano, IDS in Köln, MEDICA in Düsseldorf, SILMO in Paris, FABRICSTART in Munchen." />
        <YearCard timelineUsage year="2015" title="Dynamic Growth" highlight="Dynamic design and pavilion growth" description="A dynamic year of design, exhibitions, and pavilion construction: ISPO in Munchen, MIDO in Milano, FABRICSTART in Munchen, AMWC in Monte Carlo, Cosmoprof. in Bologna, ACHEMA in Frankfurt, OUTDOOR in Friedrichshafen, ADF CONGRESS in Paris, UNICA MILANO, IFMA in Monaco." />
        <YearCard timelineUsage year="2016" title="European & Asian Presence" highlight="Broadened European and Asian reach" description="We participated in several exhibitions across Europe and Asia: ISPO in Munchen, UNICA MILANO, MIDO in Milano, Cosmopack.prof. in Bologna, AMWC in Monte Carlo, ECR in Vienna, SMM in Hamburg, BAUMA in Munchen, EASD in Munchen, WCN in Kyoto, ISUOG in Roma, SILMO in Paris, EUROSPINE in Berlin, CPHI in Barcelona, MEDICA in Düsseldorf, UVHVS in Firenze." />
        <YearCard timelineUsage year="2017" title="Medical & Tech Focus" highlight="Medical, industrial, and tech events" description="We supported medical, industrial, and tech-focused exhibitions: ISPO in Munchen, MIDO in Milano, Cosmopack.prof. in Bologna, IDS in Köln, AMWC in Monte Carlo, EWMA in Netherlands, OUTDOOR in Friedrichshafen, EASD in Lisbon, EMO in Hannover, ESCRS in Lisbon, EUROSPINE in Dublin, Sopra della Corea in Milano, CPHI world symposium in Barcelona, CPHI in Frankfurt, MEDICA in Düsseldorf, VIE and MAD in Düsseldorf, WHITE Show in Milano, Taste of Korea in Napoli." />
        <YearCard timelineUsage year="2018" title="Cultural & Fashion Events" highlight="Cultural, fashion, and food exhibitions" description="Our projects extended to cultural, fashion, and food-related events: ISPO in Munchen, AMBIENTE in Frankfurt, MIDO in Milano, Cosmopack.prof. in Bologna, ECR in Vienna, BOOKFAIR in Leipzig, SILMO in Paris, AMWC in Monte Carlo." />
    </div>

    <div class="timeline-dots" id="timeline-dots">
        <!-- Dots will be generated dynamically -->
    </div>

    <button type="button" class="timeline-btn prev">
        <i class="fa-solid fa-chevron-left"></i>
    </button>
    <button type="button" class="timeline-btn next">
        <i class="fa-solid fa-chevron-right"></i>
    </button>
</div>

<style is:global>
    .timeline-dots {
        position: relative;
        display: flex;
        justify-content: center;
        gap: var(--spacing-2);
    }
    .timeline-dots button {
        width: 8px;
        height: 8px;
        border-radius: var(--radius-full);
        border: none;
        background: rgba(255, 255, 255, 0.3);
        cursor: pointer;
        transition: all 0.3s ease;
    }
    .timeline-dots button:hover {
        background: rgba(255, 255, 255, 0.6);
        transform: scale(1.1);
    }
    .timeline-dots button.active {
        background: var(--color-accent);
        transform: scale(1.2);
    }
</style>

<style>
    .timeline {
        position: relative;
        width: 100%;
        max-width: 1750px;
        margin: 0 auto;
        padding: var(--spacing-1) var(--spacing-8);
        overflow: hidden;
    }

    .timeline-track {
        display: flex;
        padding: 2rem 0;
        gap: var(--spacing-6);
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .timeline-btn {
        z-index: 1;
        position: absolute;
        width: 40px;
        height: 40px;
        top: 50%;
        transform: translateY(-50%);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: var(--radius-full);
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(10px);
        color: var(--color-white);
        cursor: pointer;
        transition: all 0.3s ease;
        opacity: 0.8;
    }
    .timeline-btn:hover {
        opacity: 1;
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.3);
        transform: translateY(-50%) scale(1.1);
    }
    .timeline-btn.prev {
        left: 0.25rem;
    }
    .timeline-btn.next {
        right: 0.25rem;
    }

    @media (min-width: 48rem) {
        .timeline {
            padding: var(--spacing-20);
        }

        .timeline-btn {
            width: 48px;
            height: 48px;
        }
        
        .timeline-dots button {
            width: 10px;
            height: 10px;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const timelines = document.querySelectorAll('.timeline');
        
        timelines.forEach(timeline => {
            const track = timeline.querySelector('.timeline-track');
            const cards = timeline.querySelectorAll('.timeline-card');
            const prevBtn = timeline.querySelector('.prev');
            const nextBtn = timeline.querySelector('.next');
            const dotsContainer = timeline.querySelector('.timeline-dots');
            
            let currentCard = 0;
            
            function getVisibleCards() {
                if (window.innerWidth >= 1024) return 3; // Desktop
                if (window.innerWidth >= 768) return 2;  // Tablet
                return 1; // Mobile
            }
            
            function createDots() {
                const visibleCards = getVisibleCards();
                const maxSlides = cards.length - visibleCards;
                
                // Clear existing dots
                dotsContainer.innerHTML = '';
                
                // Create new dots
                for (let i = 0; i <= maxSlides; i++) {
                    const dot = document.createElement('button');
                    dot.type = 'button';
                    dot.className = i === currentCard ? 'active' : '';
                    dot.addEventListener('click', () => {
                        currentCard = i;
                        updateTimeline();
                    });
                    dotsContainer.appendChild(dot);
                }
            }
            
            function updateTimeline() {
                const visibleCards = getVisibleCards();
                const maxSlides = cards.length - visibleCards;
                
                // Ensure currentCard doesn't exceed maxSlides
                if (currentCard > maxSlides) {
                    currentCard = maxSlides;
                }
                
                track.style.transform = `translateX(calc(-${currentCard} * (calc(100% / ${visibleCards}) + var(--spacing-6))))`;
                
                // Update dots
                const dots = dotsContainer.querySelectorAll('button');
                dots.forEach((dot, index) => {
                    dot.classList.toggle('active', index === currentCard);
                });
            }
            
            function nextCard() {
                const visibleCards = getVisibleCards();
                const maxSlides = cards.length - visibleCards;
                currentCard = (currentCard + 1) % (maxSlides + 1);
                updateTimeline();
            }
            
            function prevCard() {
                const visibleCards = getVisibleCards();
                const maxSlides = cards.length - visibleCards;
                currentCard = (currentCard - 1 + (maxSlides + 1)) % (maxSlides + 1);
                updateTimeline();
            }
            
            nextBtn.addEventListener('click', nextCard);
            prevBtn.addEventListener('click', prevCard);
            
            // Handle window resize
            window.addEventListener('resize', () => {
                const visibleCards = getVisibleCards();
                const maxSlides = cards.length - visibleCards;
                
                // Reset position if needed
                if (currentCard > maxSlides) {
                    currentCard = maxSlides;
                }
                
                createDots();
                updateTimeline();
            });
            
            // Initialize
            createDots();
            updateTimeline();
        });
    });
</script>
