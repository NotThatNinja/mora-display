---
import YearCard from './YearCard.astro';
---

<div class="timeline">
    <div class="timeline-track">
        <YearCard timelineUsage year="2010" title="Example title" highlight="Achievement!" description="Founded in London, UK with a vision to revolutionize exhibition design." />
        <YearCard timelineUsage year="2012" title="Example title" highlight="Achievement!" description="First major project: International Art Fair in London, setting new standards in immersive design." />
        <YearCard timelineUsage year="2015" title="Example title" highlight="Achievement!" description="Expanded to Europe, opening offices in Paris and Berlin." />
        <YearCard timelineUsage year="2018" title="Example title" highlight="Achievement!" description="Launched our sustainable design initiative, focusing on eco-friendly materials and practices." />
        <YearCard timelineUsage year="2020" title="Example title" highlight="Achievement!" description="Adapted to the digital age with virtual exhibition solutions during the global pandemic." />
        <YearCard timelineUsage year="2022" title="Example title" highlight="Achievement!" description="Celebrated 10 years of innovation with a major retrospective exhibition in London." />
    </div>

    <div class="timeline-dots" id="timeline-dots">
        <!-- Dots will be generated dynamically -->
    </div>

    <button type="button" class="timeline-btn prev">
        <i class="fa-solid fa-chevron-left"></i>
    </button>
    <button type="button" class="timeline-btn next">
        <i class="fa-solid fa-chevron-right"></i>
    </button>
</div>

<style is:global>
    .timeline-dots {
        position: relative;
        display: flex;
        justify-content: center;
        gap: var(--spacing-2);
    }
    .timeline-dots button {
        width: 8px;
        height: 8px;
        border-radius: var(--radius-full);
        border: none;
        background: rgba(255, 255, 255, 0.3);
        cursor: pointer;
        transition: all 0.3s ease;
    }
    .timeline-dots button:hover {
        background: rgba(255, 255, 255, 0.6);
        transform: scale(1.1);
    }
    .timeline-dots button.active {
        background: var(--color-accent);
        transform: scale(1.2);
    }
</style>

<style>
    .timeline {
        position: relative;
        width: 100%;
        max-width: 1750px;
        margin: 0 auto;
        padding: var(--spacing-1) var(--spacing-8);
        overflow: hidden;
    }

    .timeline-track {
        display: flex;
        padding: 2rem 0;
        gap: var(--spacing-6);
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .timeline-btn {
        z-index: 1;
        position: absolute;
        width: 40px;
        height: 40px;
        top: 50%;
        transform: translateY(-50%);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: var(--radius-full);
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(10px);
        color: var(--color-white);
        cursor: pointer;
        transition: all 0.3s ease;
        opacity: 0.8;
    }
    .timeline-btn:hover {
        opacity: 1;
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.3);
        transform: translateY(-50%) scale(1.1);
    }
    .timeline-btn.prev {
        left: 0.25rem;
    }
    .timeline-btn.next {
        right: 0.25rem;
    }

    @media (min-width: 48rem) {
        .timeline {
            padding: var(--spacing-20);
        }

        .timeline-btn {
            width: 48px;
            height: 48px;
        }
        
        .timeline-dots button {
            width: 10px;
            height: 10px;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const timelines = document.querySelectorAll('.timeline');
        
        timelines.forEach(timeline => {
            const track = timeline.querySelector('.timeline-track');
            const cards = timeline.querySelectorAll('.timeline-card');
            const prevBtn = timeline.querySelector('.prev');
            const nextBtn = timeline.querySelector('.next');
            const dotsContainer = timeline.querySelector('.timeline-dots');
            
            let currentCard = 0;
            
            function getVisibleCards() {
                if (window.innerWidth >= 1024) return 3; // Desktop
                if (window.innerWidth >= 768) return 2;  // Tablet
                return 1; // Mobile
            }
            
            function createDots() {
                const visibleCards = getVisibleCards();
                const maxSlides = cards.length - visibleCards;
                
                // Clear existing dots
                dotsContainer.innerHTML = '';
                
                // Create new dots
                for (let i = 0; i <= maxSlides; i++) {
                    const dot = document.createElement('button');
                    dot.type = 'button';
                    dot.className = i === currentCard ? 'active' : '';
                    dot.addEventListener('click', () => {
                        currentCard = i;
                        updateTimeline();
                    });
                    dotsContainer.appendChild(dot);
                }
            }
            
            function updateTimeline() {
                const visibleCards = getVisibleCards();
                const maxSlides = cards.length - visibleCards;
                
                // Ensure currentCard doesn't exceed maxSlides
                if (currentCard > maxSlides) {
                    currentCard = maxSlides;
                }
                
                track.style.transform = `translateX(calc(-${currentCard} * (calc(100% / ${visibleCards}) + var(--spacing-6))))`;
                
                // Update dots
                const dots = dotsContainer.querySelectorAll('button');
                dots.forEach((dot, index) => {
                    dot.classList.toggle('active', index === currentCard);
                });
            }
            
            function nextCard() {
                const visibleCards = getVisibleCards();
                const maxSlides = cards.length - visibleCards;
                currentCard = (currentCard + 1) % (maxSlides + 1);
                updateTimeline();
            }
            
            function prevCard() {
                const visibleCards = getVisibleCards();
                const maxSlides = cards.length - visibleCards;
                currentCard = (currentCard - 1 + (maxSlides + 1)) % (maxSlides + 1);
                updateTimeline();
            }
            
            nextBtn.addEventListener('click', nextCard);
            prevBtn.addEventListener('click', prevCard);
            
            // Handle window resize
            window.addEventListener('resize', () => {
                const visibleCards = getVisibleCards();
                const maxSlides = cards.length - visibleCards;
                
                // Reset position if needed
                if (currentCard > maxSlides) {
                    currentCard = maxSlides;
                }
                
                createDots();
                updateTimeline();
            });
            
            // Initialize
            createDots();
            updateTimeline();
        });
    });
</script>
