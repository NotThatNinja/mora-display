---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Timeline from '../components/Timeline.astro';
---

<Layout title="About Us - Mora Display">
    <main>
        <section class="about-hero">
            <div class="container">
                <SectionHeader
                    title="Our Complete Journey"
                    subtitle="From a small London studio to an international exhibition design powerhouse. Every milestone that shaped our passion for creating extraordinary experiences."
                />
            </div>
        </section>
        
        <section class="about-content">
            <div class="container">
                <div class="additional-content">
                    <p>우리는 전시 디자인의 혁신을 통해 고객의 브랜드 가치를 높이고, 방문객들에게 잊을 수 없는 경험을 제공합니다. 지속 가능한 디자인과 최첨단 기술을 결합하여, 미래 지향적인 전시 공간을 창조합니다. 모든 프로젝트에서 우리는 고객의 비전을 현실로 만들어내는 것을 목표로 합니다.</p>
                </div>

                <div class="timeline-container">
                    <Timeline />
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .about-hero {
        padding: calc(var(--header-height) + var(--spacing-16)) var(--spacing-4) var(--spacing-16);
        background: 
            radial-gradient(circle at 30% 70%, rgba(129, 99, 255, 0.08) 0%, transparent 50%),
            radial-gradient(circle at 70% 30%, rgba(66, 165, 245, 0.06) 0%, transparent 50%),
            var(--color-black);
    }
    
    .about-content {
        background: 
            radial-gradient(circle at 10% 20%, rgba(255, 193, 7, 0.04) 0%, transparent 50%),
            radial-gradient(circle at 90% 80%, rgba(76, 175, 80, 0.06) 0%, transparent 50%),
            var(--color-black);
    }
    
    .container {
        max-width: 1400px;
        margin: 0 auto;
    }
    
    .additional-content {
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
    }
    .additional-content p {
        line-height: var(--line-height-relaxed);
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-2xl);
        padding: var(--spacing-8);
    }
</style>
